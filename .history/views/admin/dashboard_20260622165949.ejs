<%- include('../partials/header') %>

    <div class="container py-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-bold mb-1">Admin Dashboard</h2>
                <p class="text-muted mb-0">Manage Products & Categories</p>
            </div>
            <div>
                <a href="/admin/add-product" class="btn btn-primary me-2">
                    Add Product
                </a>
                <a href="/admin/logout" class="btn btn-danger">
                    Logout
                </a>
            </div>
        </div>
                <!-- Stats Cards -->
                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                    
                                <h6 class="text-muted">
                                    Total Products
                                </h6>
                    
                                <h2 class="fw-bold text-primary">
                                    <%= products ? products.length : 0 %>
                        </h2>
                    </div>
                    </div>
                    </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Categories
                        </h6>

                        <h2 class="fw-bold text-success">
                            0
                        </h2>

                    </div>
                    </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <h6 class="text-muted">
                                    Brands
                                </h6>
                                <h2 class="fw-bold text-warning">
                                    0
                                </h2>
                            </div>
                        </div>
                    </div>
                    
                    </div>
                    
                    <!-- Product Table -->
                    
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3">

                <h5 class="mb-0">
                    Recent Products
                </h5>

            </div>

            <div class="card-body p-0">
            
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Slug</th>
                                <th>Actions</th>
                                <th>Category</th>
                                <th>Brand</th>
                                <th>Subcategory</th>
                                </tr>

                        </thead>
                        <tbody>
                            <% if(products && products.length> 0){ %>

                                <% products.forEach(product=> { %>

                                    <tr>

                                        <td>
                                            <%= product.id %>
                                        </td>

                                        <td>

                                            <% if(product.image){ %>
                                            
                                                <img src="/images/<%= product.image %>" width="70" height="70" style="object-fit:cover;">
                                            
                                                <% } else { %>
                                            
                                                    No Image
                                            
                                                    <% } %>

                                        </td>

                                        <td>
                                            <%= product.name %>
                                        </td>

                                        <td>
                                            <%= product.slug %>
                                                </td>

                                        <td>

                                            <a href="/admin/edit-product/<%= product.id %>" class="btn btn-sm btn-warning">
                                                Edit
                                            </a>

                                            <a href="/admin/delete-product/<%= product.id %>" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Delete this product?')">
                                                Delete
                                            </a>

                                        </td>

                                    </tr>

                                    <% }) %>

                                        <% } else { %>

                                            <tr>

                                                <td colspan="5" class="text-center py-4">
                                                    No Products Found
                                                </td>

                                            </tr>

                                            <% } %>
                                            
                                                </tbody>

                    </table>

                </div>
                
                </div>
                
                </div>

    </div>

    <%- include('../partials/footer') %>