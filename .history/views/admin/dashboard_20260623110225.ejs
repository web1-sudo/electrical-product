<%- include('../partials/header') %>

    <div class="container py-5">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-bold mb-1">Admin Dashboard</h2>
                <p class="text-muted mb-0">Manage Products & Categories</p>
            </div>
            <div>
                <a href="/admin/add-product" class="btn btn-primary me-2">
                    Add Product
                </a>
                <a href="/admin/logout" class="btn btn-danger">
                    Logout
                </a>
            </div>
        </div>
                <!-- Stats Cards -->
                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                    
                                <h6 class="text-muted">
                                    Total Products
                                </h6>
                    
                                <h2 class="fw-bold text-primary">
                                    <%= products ? products.length : 0 %>
                        </h2>
                    </div>
                    </div>
                    </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">

                        <h6 class="text-muted">
                            Categories
                        </h6>

                        <h2 class="fw-bold text-success">
                            0
                        </h2>

                    </div>
                    </div>
                    </div>
                    
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <h6 class="text-muted">
                                    Brands
                                </h6>
                                <h2 class="fw-bold text-warning">
                                    0
                                </h2>
                            </div>
                        </div>
                    </div>
                    
                    </div>
                    
                    <!-- Product Table -->
                    
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3">

                <h5 class="mb-0">
                    Recent Products
                </h5>

            </div>

            <div class="card-body p-0">
            
            <div class="table-responsive">
            
                <table class="table table-hover align-middle mb-0" style="width:100%; white-space:nowrap;">
            
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Main Image</th>
                            <th>Product Name</th>
                            <th>Brand</th>
                            <th>Category</th>
                            <th>Sub Category</th>
                            <th>Rating</th>
                            <th>Poles</th>
                            <th>Image 2</th>
                            <th>Image 3</th>
                            <th>PDF</th>
                            <th>Description</th>
                            <th>Created At</th>
                            <th>Action</th>
                        </tr>
                    </thead>
            
                    <tbody>
            
                        <% if(products && products.length> 0){ %>
            
                            <% products.forEach(product=> { %>
            
                                <tr>
            
                                    <td>
                                        <%= product.id %>
                                    </td>
            
                                    <!-- Main Image -->
                                    <td>
                                        <% if(product.image){ %>
                                            <img src="/images/<%= product.image %>" width="70" height="70"
                                                style="object-fit:cover;">
                                            <% } else { %>
                                                No Image
                                                <% } %>
                                    </td>
            
                                    <!-- Product Name -->
                                    <td>
                                        <%= product.name || '-' %>
                                    </td>
            
                                    <!-- Brand -->
                                    <td>
                                        <%= product.brand || '-' %>
                                    </td>
            
                                    <!-- Category -->
                                    <td>
                                        <%= product.category || '-' %>
                                    </td>
            
                                    <!-- Subcategory -->
                                    <td>
                                        <%= product.subcategory || '-' %>
                                    </td>
            
                                    <!-- Rating -->
                                    <td>
                                        <%= product.rating || '-' %>
                                    </td>
            
                                    <!-- Poles -->
                                    <td>
                                        <%= product.poles || '-' %>
                                    </td>
            
                                    <!-- Image 2 -->
                                    <td>
                                        <% if(product.image2){ %>
                                            <img src="/images/<%= product.image2 %>" width="70" height="70"
                                                style="object-fit:cover;">
                                            <% } else { %>
                                                No Image
                                                <% } %>
                                    </td>
            
                                    <!-- Image 3 -->
                                    <td>
                                        <% if(product.image3){ %>
                                            <img src="/images/<%= product.image3 %>" width="70" height="70"
                                                style="object-fit:cover;">
                                            <% } else { %>
                                                No Image
                                                <% } %>
                                    </td>
            
                                    <!-- PDF -->
                                    <td>
                                        <% if(product.pdf){ %>
                                            <a href="/images/<%= product.pdf %>" target="_blank" class="btn btn-sm btn-info">
                                                View PDF
                                            </a>
                                            <% } else { %>
                                                No PDF
                                                <% } %>
                                    </td>
            
                                    <!-- Description -->
                                    <td style="max-width:300px;">
                                        <%= product.description || '-' %>
                                    </td>
            
                                    <!-- Created At -->
                                    <td>
                                        <%= product.created_at || '-' %>
                                    </td>
            
                                    <!-- Actions -->
                                    <td>
                                        <a href="/admin/edit-product/<%= product.id %>" class="btn btn-sm btn-warning mb-1">
                                            Edit
                                        </a>
            
                                        <a href="/admin/delete-product/<%= product.id %>" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Delete this product?')">
                                            Delete
                                        </a>
                                    </td>
            
                                </tr>
            
                                <% }) %>
            
                                    <% } else { %>
            
                                        <tr>
                                            <td colspan="14" class="text-center py-4">
                                                No Products Found
                                            </td>
                                        </tr>
            
                                        <% } %>
            
                    </tbody>
            
                </table>
            
            </div>
                
                </div>
                
                </div>

    </div>

    <%- include('../partials/footer') %>