<%- include('../partials/header') %>

    <section class="product-page py-5">

        <div class="container">

            <!-- Breadcrumb -->

            <div class="breadcrumb mb-4">

                <a href="/">Home</a>

                <span> ></span>

                <a href="/products">Products</a>

                <span> ></span>

                <a href="/products/<%= categorySlug %>">
                    <%= categoryName %>
                </a>

                <span> ></span>

                <strong>
                    <%= brandName %>
                </strong>

            </div>

            <!-- Page Title -->

            <div class="section-title text-center mb-5">

                <h1>
                    <%= brandName %>
                </h1>

            </div>

            <div class="row">
<% if(categorySlug==='distribution-boards' ){ %>

    <div class="product-tabs mb-4">

        <a href="?tab=auralis" class="btn <%= activeTab === 'auralis' ? 'btn-danger' : 'btn-outline-danger' %>">
            Auralis
        </a>

        <a href="?tab=elvo" class="btn <%= activeTab === 'elvo' ? 'btn-danger' : 'btn-outline-danger' %>">
            Elvo
        </a>

        <a href="?tab=avina" class="btn <%= activeTab === 'avina' ? 'btn-danger' : 'btn-outline-danger' %>">
            Avina
        </a>

    </div>

    <% } %>

<% if(brandSlug==='eq9' ){ %>

    <div class="product-tabs mb-4">

        <a href="?tab=mcb" class="btn <%= activeTab === 'mcb' ? 'btn-danger' : 'btn-outline-danger' %>">
            MCB
        </a>

        <a href="?tab=isolator" class="btn <%= activeTab === 'isolator' ? 'btn-danger' : 'btn-outline-danger' %>">
            Isolator
        </a>

    </div>

    <% } %>

                <!-- FILTERS -->

                <div class="col-lg-3 mb-4">

                    <div class="filter-box p-3 border rounded">

                        <h4 class="mb-4">
                            Filters
                        </h4>

                    <form id="filterForm" method="GET">
                    
                        <input type="hidden" name="tab" value="<%= activeTab %>">

                            <% if(brandSlug==='eq9' ){ %>

                                <!-- Rating -->

                                <h6 class="fw-bold mb-3">
                                    Current Rating
                                </h6>

                                <% ratings.forEach(function(item){ %>

                                    <div class="form-check mb-2">

                                    <input class="form-check-input" type="checkbox" name="rating" value="<%= item %>"
                                        <%=Array.isArray(selectedFilters.rating) ? selectedFilters.rating.includes(item) ? 'checked' : '' :
                                        selectedFilters.rating===item ? 'checked' : '' %>
                                    onchange="document.getElementById('filterForm').submit()">


                                        <label class="form-check-label">
                                            <%= item %>
                                        </label>

                                    </div>

                                    <% }) %>

                                        <hr>

                                        <!-- Poles -->

                                        <h6 class="fw-bold mb-3">
                                            No Of Poles
                                        </h6>

                                        <% poles.forEach(function(item){ %>

                                            <div class="form-check mb-2">

                                        <input class="form-check-input" type="checkbox" name="poles" value="<%= item %>" <%=Array.isArray(selectedFilters.poles)
                                            ? selectedFilters.poles.includes(item) ? 'checked' : '' : selectedFilters.poles===item ? 'checked' : '' %>
                                        onchange="document.getElementById('filterForm').submit()">

                                                <label class="form-check-label">
                                                    <%= item %>
                                                </label>

                                            </div>

                                            <% }) %>

                                                <% } %>

                                                    <% if(brandSlug==='auralis' ){ %>

                                                        <h6 class="fw-bold mb-3">
                                                        <% if(activeTab==='auralis' ){ %>
                                                        
                                                            Boards Filter
                                                        
                                                            Boards Type Filter
                                                        
                                                            <% } %>
                                                        </h6>

                                                        <% boards.forEach(function(item){ %>

                                                            <div class="form-check mb-2">

                                                            <input class="form-check-input" type="checkbox" name="boards" value="<%= item %>"
                                                                <%=Array.isArray(selectedFilters.boards) ? selectedFilters.boards.includes(item) ? 'checked' : '' :
                                                                selectedFilters.boards===item ? 'checked' : '' %>
                                                            onchange="document.getElementById('filterForm').submit()">

                                                                <label class="form-check-label">
                                                                    <%= item %>
                                                                </label>

                                                            </div>

                                                            <% }) %>

                                                                <hr>

                                                                <h6 class="fw-bold mb-3">
                                                                    Boards Type
                                                                </h6>

                                                                <% boardTypes.forEach(function(item){ %>

                                                                    <div class="form-check mb-2">

                                                                    <input class="form-check-input" type="checkbox" name="boards_type" value="<%= item %>"
                                                                        <%=Array.isArray(selectedFilters.boards_type) ? selectedFilters.boards_type.includes(item) ? 'checked' : '' :
                                                                        selectedFilters.boards_type===item ? 'checked' : '' %>
                                                                    onchange="document.getElementById('filterForm').submit()">

                                                                        <label class="form-check-label">
                                                                            <%= item %>
                                                                        </label>

                                                                    </div>

                                                                    <% }) %>

                                                                        <% } %>

                                                                            <% if(brandSlug==='elvo' ){ %>

                                                                                <h6 class="fw-bold mb-3">
                                                                                <% if(activeTab==='elvo' ){ %>
                                                                                
                                                                                    Boards Filter
                                                                                
                                                                                    <% } %>
                                                                                </h6>

                                                                                <% boards.forEach(function(item){ %>

                                                                                    <div class="form-check mb-2">

                                                                                    <input class="form-check-input" type="checkbox" name="boards" value="<%= item %>"
                                                                                        <%=Array.isArray(selectedFilters.boards) ? selectedFilters.boards.includes(item) ? 'checked' : '' :
                                                                                        selectedFilters.boards===item ? 'checked' : '' %>
                                                                                    onchange="document.getElementById('filterForm').submit()">

                                                                                        <label class="form-check-label">
                                                                                            <%= item %>
                                                                                        </label>

                                                                                    </div>

                                                                                    <% }) %>

                                                                                        <% } %>

                                                                                            <% if(brandSlug==='avina' ){
                                                                                                %>

                                                                                                <h6
                                                                                                    class="fw-bold mb-3">
                                                                                                <% if(activeTab==='avina' ){ %>
                                                                                                
                                                                                                    Boards Type Filter
                                                                                                
                                                                                                    <% } %>
                                                                                                </h6>

                                                                                                <% boardTypes.forEach(function(item){
                                                                                                    %>

                                                                                                    <div
                                                                                                        class="form-check mb-2">

                                                                                                        <input
                                                                                                            class="form-check-input"
                                                                                                            type="checkbox"
                                                                                                            name="boards_type"
                                                                                                            value="<%= item %>"
                                                                                                            onchange="document.getElementById('filterForm').submit()">

                                                                                                        <label
                                                                                                            class="form-check-label">
                                                                                                            <%= item %>
                                                                                                        </label>

                                                                                                    </div>

                                                                                                    <% }) %>

                                                                                                        <% } %>

                        </form>

                    </div>

                </div>

            <!-- PRODUCT CARDS -->

                <div class="col-lg-9">

                    <div class="row g-4">

                    <% products.forEach(function(product){ %>
                    
                        <div class="col-lg-4 col-md-6">
                    
                            <a href="/product/<%= product.slug %>" class="text-decoration-none text-dark">
                    
                                <div class="product-card">
                    
                                    <div class="product-card-image">
                    
                                        <img src="/images/<%= product.image %>" alt="<%= product.name %>" class="img-fluid">
                    
                                    </div>
                    
                                    <div class="product-card-content text-center p-3">
                    
                                        <h5>
                                            <%= product.name %>
                                        </h5>
                    
                                    </div>
                    
                                </div>
                    
                            </a>
                    
                        </div>
                    
                        <% }) %>

<% if(totalPages> 1){ %>

    <div class="row justify-content-center mt-5">

        <div class="col-auto">

            <nav>

                <ul class="pagination">

                    <% if(page> 1){ %>

                        <li class="page-item">

                            <a class="page-link" href="?page=<%= page - 1 %>">
                                &lt;
                            </a>

                        </li>

                        <% } %>

                            <% for(let i=1; i <=totalPages; i++){ %>

                                <li class="page-item <%= page === i ? 'active' : '' %>">

                                    <a class="page-link" href="?page=<%= i %>">
                                        <%= i %>
                                    </a>

                                </li>

                                <% } %>

                                    <% if(page < totalPages){ %>

                                        <li class="page-item">

                                            <a class="page-link" href="?page=<%= page + 1 %>">
                                                &gt;
                                            </a>

                                        </li>

                                        <% } %>

                </ul>

            </nav>

        </div>

    </div>

    <% } %>

    <% } %>
                </div>





            </div>

        </div>

    </section>

    <%- include('../partials/footer') %>