<%- include('../partials/header') %>

    <section class="product-banner py-5">
        <img src="images/EQ9.png" alt="product image" class="banner-bg-img">
        <div class="container">

            <div class="text-content-banner">
                <div class="breadcrumb">
                    <div class="d-flex align-items-center">
                        <a href="/">Home</a>
                        <span class="mx-2" style="font-weight: 400; color: #999;">&gt;</span>

                        <a href="/products/<%= categorySlug %>">
                            <%= categoryName %>
                        </a>
                        <span class="mx-2" style="font-weight: 400; color: #999;">&gt;</span>

                        <strong>
                            <%= brandName %>
                        </strong>
                    </div>
                </div>

                <h1>
                    <%= brandName %>
                </h1>
            </div>
        </div>
    </section>


    <section class="product-content">
        <div class="container">
            <div class="text-lg-start">
                <h2>
                    Our Products
                </h2>
                <p>
                    Alric Electric’s EQ9 series premium MCBs provides reliable and safe protection against overloads and
                    short circuits with
                    best-in-class technology <br class="d-lg-block d-none"> and infrastructure. These MCBs are
                    manufactured with recyclable
                    fire-retardant engineering
                    plastics ensuring safety and durability. <br class="d-lg-block d-none">
                    These MCBs are must-have safety product for distribution of power at homes, residential / commercial
                    buildings /
                    industrial applications.  
                </p>
            </div>
        </div>
        <div class="container ">
            <div class="row">
                <% if(categorySlug==='distribution-boards' ){ %>

                    <div class="product-tabs tabs text-center ">
                        <a href="/products/distribution-boards/auralis?tab=auralis"
                            class="btn <%= activeTab === 'auralis' ? 'btn-theme-danger' : 'btn-theme-danger-outline' %>">
                            Auralis
                        </a>

                        <a href="/products/distribution-boards/elvo?tab=elvo"
                            class="btn <%= activeTab === 'elvo' ?  'btn-theme-danger' : 'btn-theme-danger-outline' %>">
                            Elvo
                        </a>

                        <a href="/products/distribution-boards/avina?tab=avina"
                            class="btn <%= activeTab === 'avina' ?  'btn-theme-danger' : 'btn-theme-danger-outline' %>">
                            Avina
                        </a>


                    </div>

                    <% } %>

                        <% if(brandSlug==='eq9' ){ %>

                            <div class="product-tabs text-center tabs">

                                <a href="?tab=mcb"
                                    class="btn <%= activeTab === 'mcb' ? 'btn-theme-danger' : 'btn-theme-danger-outline' %>">
                                    MCB
                                </a>

                                <a href="?tab=isolator"
                                    class="btn <%= activeTab === 'isolator' ? 'btn-theme-danger' : 'btn-theme-danger-outline' %>">
                                    Isolator
                                </a>

                            </div>

                            <% } %>

                             

            </div>
<div class="row"></div>
           
        </div>
    </section>

    <%- include('../partials/footer') %>