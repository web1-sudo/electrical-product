                    </p>
                </div>
                <div class="col-md-4">
                    <div class="d-flex justify-content-lg-end justify-content-start align-items-center">
                        <a href="#" class="f-size btn btn-theme-danger me-3">download catalogue</a>
                        <a href="support" class=" btn btn-theme-outline">support</a>
                    </div>

                </div>
            </div>
        </div>
    </section>


    <%- include('partials/footer') %>