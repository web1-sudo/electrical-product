<%- include('partials/header') %>

    <section class="banner-page">
        <div class="container-fluid padding-x">
            <div class="row align-items-center justify-content-between gy-4">
                <div class="col-lg-6 ">

                    <div class="breadcrumb">
                        <div class="d-flex align-items-center">

                            <a href="/">
                                Home
                            </a>

                            <span>
                                >
                            </span>
                            <span>
                                Contact
                            </span>
                        </div>
                    </div>

                    <span class="section-label">Contact</span>
                    <h1>Let’s start a
                        <br class="d-lg-block d-none"> <span>conversation .</span>
                    </h1>
                    <p>Whether you are an architect, contractor, developer or homeowner <br class="d-lg-block d-none">
                        - we would love to hear from you. Our team responds within 1-2 <br class="d-lg-block d-none">
                        business days.</p>
                </div>

            </div>
        </div>
    </section>


    <section class="page-section bg-white">
        <div class="container-fluid padding-x">
            <div class="row justify-content-between align-items-start">
                <div class="col-md-6">
                    <span class="section-label">get in touch</span>
                    <h2 class="mt-4 mb-3 fw-bold">
                        Send us a message.
                    </h2>
                    <p>
                        Tell us about your project or enquiry and our team will get <br class="d-lg-block d-none">
                        back to you within 1-2 business days.
                    </p>
                </div>
                <div class="col-md-5 form-support" >


        
                    <form action="/contact" method="POST" class="pe-3" id="contactForm" >
                        <div class="row align-items-center justify-content-between">
                            <div class="col-md-4 mb-3">
                                <label for="First-name-support">First name</label>
                                <input type="text" id="First-name-support" name="firstName" class="form-control"
                                    required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label for="Last-name-support">Last name</label>
                                <input type="text" id="Last-name-support" name="lastName" class="form-control" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label for="phone-support">Phone</label>
                                <input type="number" id="phone-support" name="phone" class="form-control" required>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label for="email-address-support">Email address</label>
                                <input type="email" id="email-address-support" name="email" class="form-control"
                                    required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label for="company-support">Company / Project</label>
                                <input type="text" id="company-support" name="company" class="form-control" required>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label for="enquiry-support">Enquiry type</label>
                                <!-- <input type="text" id="enquiry-support" name="enquiryType" class="form-control"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    required> -->
                                <select name="topic" id="topic" class="form-select" required>
                                    <option value="" disabled selected>Select a topic</option>
                                    <option value="product-information">Product Information</option>
                                    <option value="technical-support">Technical Support</option>
                                    <option value="sample-request">Sample Request</option>
                                    <option value="warranty">Warranty</option>
                                    <option value="dealer-distribution">Dealer / Distribution</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label for="massage-support">Message</label>
                                <textarea id="massage-support" name="message" class="form-control" required></textarea>
                            </div>

                            <div class="col-md-4">
                                <button type="submit" class="btn btn-theme-danger my-2"  >
                                    Send Message
                                </button>

                            </div>
                            <% if (success) { %>
                            
                                <div class="alert <%= success === 'Email Sent Successfully' ? 'alert-success' : 'alert-danger' %>">
                                    <%= success %>
                                </div>
                            
                                <% } %>
                        </div>
                       
                    </form>
                </div>
            </div>
        </div>
    </section>

