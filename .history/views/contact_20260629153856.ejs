    <section class="about-contact-section">
        <div class="container-fluid padding-x">
            <div class="row justify-content-between align-items-center">
                <div class="col-md-6">
                    <h2>
                        Ready to <br class="d-lg-none d-block" > <span>
                            specify Alric Electric?
                        </span>
                    </h2>
                    <p>
                        Architects and contractors can request technical datasheets, product samples or a full project
