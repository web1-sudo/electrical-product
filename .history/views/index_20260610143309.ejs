<%- include('partials/header') %>

    <div class="container py-5">

        <div class="row">

            <!-- SIDEBAR -->

            <div class="col-lg-3">

                <div class="filter-box p-3 bg-white">

                    <h4 class="mb-4">

                        Filters

                    </h4>


                    <!-- BUTTON FILTER -->

                    <div class="mb-4">

                        <a href="/products" class="btn btn-outline-primary mb-2">

                            All

                        </a>

                        <a href="/products?type=MCB" class="btn btn-outline-primary mb-2">

                            MCB

                        </a>

                        <a href="/products?type=Isolator" class="btn btn-outline-primary mb-2">

                            Isolator

                        </a>

                    </div>


                    <!-- SEARCH -->

                    <form action="/products">

                        <input type="text" name="search" class="form-control mb-3" placeholder="Search Product"
                            value="<%= filters.search %>">


                        <!-- RATING -->

                        <h5>Current Rating</h5>

                        <select name="rating" class="form-select mb-3">

                            <option value="">
                                All
                            </option>

                            <option value="06A">
                                06A
                            </option>

                            <option value="32A">
                                32A
                            </option>

                        </select>



                        <!-- CURVE -->

                        <h5>Curve Type</h5>

                        <select name="curve" class="form-select mb-3">

                            <option value="">
                                All
                            </option>

                            <option value="B">
                                B
                            </option>

                            <option value="C">
                                C
                            </option>

                        </select>



                        <!-- POLES -->

                        <h5>No of Poles</h5>

                        <select name="poles" class="form-select mb-3">

                            <option value="">
                                All
                            </option>

                            <option value="Single Pole">
                                Single Pole
                            </option>

                            <option value="Double Pole">
                                Double Pole
                            </option>

                        </select>



                        <!-- SORT -->

                        <h5>Sort</h5>

                        <select name="sort" class="form-select mb-3">

                            <option value="">
                                Default
                            </option>

                            <option value="latest">
                                Latest
                            </option>

                            <option value="oldest">
                                Oldest
                            </option>

                        </select>


                        <button type="submit" class="btn btn-primary w-100">

                            Apply Filters

                        </button>

                    </form>

                </div>

            </div>



            <!-- PRODUCTS -->

            <div class="col-lg-9">

                <div class="row">

                    <% products.forEach(product=> { %>

                        <div class="col-lg-4 mb-4">

                            <a href="/product/<%= product.slug %>" class="product-link">

                                <div class="card product-card">

                                    <!-- <img src="/images/<%= product.image %>" class="product-image"> -->

                                    <img loading="lazy" src="/images/<%= product.image %>" <div class="card-body">

                                    <h5>
                                        <%= product.name %>
                                    </h5>

                                    <p>
                                        <%= product.brand %>
                                    </p>

                                    <p>
                                        <%= product.currentRating %>
                                    </p>

                                </div>

                        </div>

                        </a>

                </div>

                <% }) %>

            </div>



            <!-- PAGINATION -->

            <div class="pagination-box mt-5">

                <% for(let i=1; i<=totalPages; i++){ %>

                    <a href="/products?page=<%= i %>" class="btn btn-outline-primary me-2">

                        <%= i %>

                    </a>

                    <% } %>

            </div>

        </div>

    </div>

    </div>

    <%- include('partials/footer') %>