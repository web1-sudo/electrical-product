<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">


    <title>

        <%= typeof product !=='undefined' ? product.meta_title || product.name : 'Electrical Products Website' %>

    </title>


    <meta name="description" content="<%= typeof product !== 'undefined'
? product.meta_description
: 'Electrical Products Website' %>">


    <!-- Bootstrap -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


    <!-- CSS -->

    <link rel="stylesheet" href="/css/style.css">


    <!-- OPEN GRAPH -->

    <meta property="og:title" content="<%= typeof product !== 'undefined'
? product.name
: 'Electrical Website' %>">


    <meta property="og:description" content="<%= typeof product !== 'undefined'
? product.meta_description
: 'Electrical Website' %>">


    <meta property="og:image" content="<%= typeof product !== 'undefined'
? '/images/' + product.image
: '' %>">


    <!-- SCHEMA -->

    <% if(typeof product !=='undefined' ){ %>

        <script type="application/ld+json">

{
"@context":"https://schema.org",
"@type":"Product",

"name":"<%= product.name %>",

"image":
"/images/<%= product.image %>",

"description":
"<%= product.meta_description %>",

"brand":{
"@type":"Brand",
"name":"<%= product.brand %>"
}

}

</script>

        <% } %>

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/images/logo.svg" alt="logo">
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link nav-link-item text-danger fw-bold active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-item text-secondary fw-semibold" href="/about">About</a>
                    </li>

                    <li class="nav-item dropdown position-static px-2">
                        <a class="nav-link nav-link-item text-secondary fw-semibold dropdown-toggle hide-caret" href="#"
                            id="productsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            PRODUCTS
                        </a>

                        <div class="dropdown-menu mega-menu-wrapper border-0 rounded-bottom shadow p-4"
                            aria-labelledby="productsDropdown">
                            <div class="row mx-0">

                                <div class="col-lg-5 border-end border-light-subtle">
                                    <ul class="list-unstyled mb-0">
                                        <li class="category-item py-2 fw-semibold text-danger border-bottom border-light-subtle cursor-pointer active"
                                            data-target="protection">PROTECTION DEVICES</li>
                                        <li class="category-item py-2 fw-semibold text-secondary border-bottom border-light-subtle cursor-pointer"
                                            data-target="switches">SWITCHES & ACCESSORIES</li>
                                        <li class="category-item py-2 fw-semibold text-secondary cursor-pointer"
                                            data-target="distribution">DISTRIBUTION BOARDS</li>
                                    </ul>
                                </div>

                                <div class="col-lg-3 px-4">
                                    <span class="d-block text-danger fw-bold mb-3 tracking-wide"
                                        style="font-size: 11px;">BRANDS</span>

                                    <div id="protection" class="brand-group d-flex flex-column gap-2 active">
                                        <a href="#" class="text-dark fw-bold text-decoration-none small">EQ9</a>
                                        <a href="#" class="text-muted fw-semibold text-decoration-none small">MCB</a>
                                        <a href="#"
                                            class="text-muted fw-semibold text-decoration-none small">Isolator</a>
                                    </div>

                                    <div id="switches" class="brand-group d-none flex-column gap-2">
                                        <a href="#" class="text-muted fw-semibold text-decoration-none small">Elvyx</a>
                                    </div>

                                    <div id="distribution" class="brand-group d-none flex-column gap-2">
                                        <a href="#"
                                            class="text-muted fw-semibold text-decoration-none small">Auralis</a>
                                        <a href="#" class="text-muted fw-semibold text-decoration-none small">Elvo</a>
                                        <a href="#" class="text-muted fw-semibold text-decoration-none small">Avina</a>
                                    </div>
                                </div>

                                <div
                                    class="col-lg-4 bg-light rounded d-flex align-items-center justify-content-center p-3">
                                    <div id="img-protection" class="product-img-wrapper active">
                                        <img src="https://via.placeholder.com/160x160?text=MCB+Device" class="img-fluid"
                                            alt="Protection Device">
                                    </div>
                                    <div id="img-switches" class="product-img-wrapper d-none">
                                        <img src="https://via.placeholder.com/160x160?text=Switch" class="img-fluid"
                                            alt="Switches">
                                    </div>
                                    <div id="img-distribution" class="product-img-wrapper d-none">
                                        <img src="https://via.placeholder.com/160x160?text=DB+Box" class="img-fluid"
                                            alt="Distribution Board">
                                    </div>
                                </div>

                            </div>
                        </div>
                    </li>

                    <li class="nav-item"><a class="nav-link nav-link-item text-secondary fw-semibold"
                            href="/support">Support</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-item text-secondary fw-semibold"
                            href="/career">Career</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-item text-secondary fw-semibold"
                            href="/contact">Contact</a></li>
                </ul>
                <a href="/contact" class="btn btn-theme-danger">ENQUIRE NOW</a>
            </div>
        </div>
    </nav>