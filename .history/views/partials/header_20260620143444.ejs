<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof product !=='undefined' ? product.meta_title || product.name : 'Electrical Products Website' %>
    </title>
    <meta name="description"
        content="<%= typeof product !== 'undefined' ? product.meta_description : 'Electrical Products Website' %>">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/style.css">

    <!-- OPEN GRAPH -->
    <meta property="og:title" content="<%= typeof product !== 'undefined' ? product.name : 'Electrical Website' %>">
    <meta property="og:description"
        content="<%= typeof product !== 'undefined' ? product.meta_description : 'Electrical Website' %>">
    <meta property="og:image" content="<%= typeof product !== 'undefined' ? '/images/' + product.image : '' %>">

    <!-- SCHEMA -->
    <% if (typeof product !=='undefined' ) { %>
        <script type="application/ld+json">
  {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "<%= product.name %>",
      "image": "/images/<%= product.image %>",
      "description": "<%= product.meta_description %>",
      "brand": {
     "@type": "Brand",
     "name": "<%= product.brand %>"
      }
  }
   </script>
        <% } %>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top">
        <div class="container">
            <a class="navbar-brand  d-flex align-items-center" href="/">
                <img src="/images/logo.svg" alt="logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link nav-link-item text-danger  active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-item text-secondary" href="/about">About</a>
                    </li>

                    <li class="nav-item dropdown position-static">
                        <a class="nav-link nav-link-item text-secondary   dropdown-toggle hide-caret" href="#"
                            id="productsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            PRODUCTS
                        </a>

                        <div class="dropdown-menu mega-menu-wrapper border-0  shadow p-4"
                            aria-labelledby="productsDropdown">
                            <div class="row mx-0">

                                <div class="col-lg-5  border-light-subtle">
                                    <ul class="list-unstyled mb-0">
                                        <li class="category-item py-2   text-danger border-bottom border-light-subtle cursor-pointer active"
                                            data-target="protection">PROTECTION DEVICES</li>
                                        <li class="category-item py-2   text-secondary border-bottom border-light-subtle cursor-pointer"
                                            data-target="switches">SWITCHES & ACCESSORIES</li>
                                        <li class="category-item py-2   text-secondary cursor-pointer"
                                            data-target="distribution">DISTRIBUTION BOARDS</li>
                                    </ul>
                                </div>

                                <div class="col-lg-3 px-4">
                                    <span class="d-block text-danger  mb-3 tracking-wide"
                                        style="font-size: 11px;">BRANDS</span>

                                    <div id="protection" class="brand-group  d-flex flex-column gap-2 active">
                                        <a href="#" class="text-dark   ">EQ9</a>
                                        <a href="#" class="">MCB</a>
                                        <a href="#" class="">Isolator</a>
                                    </div>

                                    <div id="switches" class="brand-group d-none flex-column gap-2">
                                        <a href="#" class="">Elvyx</a>
                                    </div>

                                    <div id="distribution" class="brand-group d-none flex-column gap-2">
                                        <a href="#" class="">Auralis</a>
                                        <a href="#" class="">Elvo</a>
                                        <a href="#" class="">Avina</a>
                                    </div>
                                </div>

                                <div
                                    class="col-lg-4 bg-light rounded d-flex align-items-center justify-content-center p-3">
                                    <div id="img-protection" class="product-img-wrapper active">
                                        <img src="/images/protection.png" class="img-fluid" alt="Protection Device">
                                    </div>
                                    <div id="img-switches" class="product-img-wrapper d-none">
                                        <img src="/images/swiches.png" class="img-fluid" alt="Switches">
                                    </div>
                                    <div id="img-distribution" class="product-img-wrapper d-none">
                                        <img src="/images/boards.png" class="img-fluid" alt="Distribution Board">
                                    </div>
                                </div>

                            </div>
                        </div>
                    </li>

                    <li class="nav-item"><a class="nav-link nav-link-item text-secondary  " href="/support">Support</a>
                    </li>
                    <li class="nav-item"><a class="nav-link nav-link-item text-secondary  " href="/career">Career</a>
                    </li>
                    <li class="nav-item"><a class="nav-link nav-link-item text-secondary  " href="/contact">Contact</a>
                    </li>
                </ul>

                <button type="button" class="btn btn-theme-danger" data-bs-toggle="modal"
                    data-bs-target="#exampleModal">
                    ENQUIRE NOW
                </button>
            </div>
        </div>
    </nav>
    <div class="header-spacer"></div>