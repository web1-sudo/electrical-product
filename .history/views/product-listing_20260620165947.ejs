<%- include('partials/header') %>

    <section class="py-5">
        <div class="container">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="fw-bold">Products</h1>
                    <p class="text-muted mb-0">
                        Browse our electrical product range
                    </p>
                </div>
            </div>

            <!-- FILTERS -->

            <form method="GET" action="/products" class="mb-5">

                <div class="row g-3">

                    <div class="col-md-3">
                        <input type="text" name="search" class="form-control" placeholder="Search Product"
                            value="<%= filters.search || '' %>">
                    </div>

                    <div class="col-md-2">
                        <select name="type" class="form-select">
                            <option value="">All Types</option>
                            <option value="MCB" <%=filters.type==='MCB' ? 'selected' : '' %>>
                                MCB
                            </option>
                            <option value="Isolator" <%=filters.type==='Isolator' ? 'selected' : '' %>>
                                Isolator
                            </option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select name="category" class="form-select">
                            <option value="">All Categories</option>
                            <option value="Protection Devices">
                                Protection Devices
                            </option>
                            <option value="Switches & Accessories">
                                Switches & Accessories
                            </option>
                            <option value="Distribution Boards">
                                Distribution Boards
                            </option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select name="sort" class="form-select">
                            <option value="">Sort</option>

                            <option value="latest" <%=filters.sort==='latest' ? 'selected' : '' %>>
                                Latest
                            </option>

                            <option value="oldest" <%=filters.sort==='oldest' ? 'selected' : '' %>>
                                Oldest
                            </option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button class="btn btn-primary w-100">
                            Filter Products
                        </button>
                    </div>

                </div>

            </form>

            <!-- PRODUCTS -->

            <div class="row g-4">

                <% if(products.length> 0){ %>

                    <% products.forEach(product=> { %>

                        <div class="col-lg-3 col-md-4 col-sm-6">

                            <div class="card h-100 shadow-sm border-0">

                                <div class="p-3 text-center">

                                    <img src="/uploads/<%= product.image %>" class="img-fluid"
                                        style="height:220px;object-fit:contain;" alt="<%= product.name %>">

                                </div>

                                <div class="card-body">

                                    <span class="badge bg-light text-dark mb-2">
                                        <%= product.category %>
                                    </span>

                                    <h5 class="card-title">
                                        <%= product.name %>
                                    </h5>

                                    <p class="text-muted small">
                                        <%= product.brand %>
                                    </p>

                                </div>

                                <div class="card-footer bg-white border-0">

                                    <a href="/product/<%= product.slug %>" class="btn btn-primary w-100">
                                        View Product
                                    </a>

                                </div>

                            </div>

                        </div>

                        <% }) %>

                            <% } else { %>

                                <div class="col-12">

                                    <div class="alert alert-warning">
                                        No Products Found
                                    </div>

                                </div>

                                <% } %>

            </div>

            <!-- PAGINATION -->

            <% if(totalPages> 1){ %>

                <nav class="mt-5">

                    <ul class="pagination justify-content-center">

                        <% for(let i=1; i <=totalPages; i++){ %>

                            <li class="page-item <%= filters.page == i ? 'active' : '' %>">

                                <a class="page-link" href="?page=<%= i %>">
                                    <%= i %>
                                </a>

                            </li>

                            <% } %>

                    </ul>

                </nav>

                <% } %>

        </div>
    </section>

    <%- include('partials/footer') %>