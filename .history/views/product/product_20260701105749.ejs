    <%- include('../partials/footer') %>


    <script>
    console.log("<%= product.variant1_datasheet %>");
    console.log("<%= product.variant2_datasheet %>");
    console.log("<%= product.variant3_datasheet %>");
    console.log("<%= product.variant4_datasheet %>");
        const variants = {
            1: {
                datasheet: "<%= product.variant1_datasheet %>",
                catalog: "<%= product.variant1_catalog %>",
                installation: "<%= product.variant1_installation %>"
            },
            2: {
                datasheet: "<%= product.variant2_datasheet %>",
                catalog: "<%= product.variant2_catalog %>",
                installation: "<%= product.variant2_installation %>"
            },
            3: {
                datasheet: "<%= product.variant3_datasheet %>",
                catalog: "<%= product.variant3_catalog %>",
                installation: "<%= product.variant3_installation %>"
            },
            4: {
                datasheet: "<%= product.variant4_datasheet %>",
                catalog: "<%= product.variant4_catalog %>",
                installation: "<%= product.variant4_installation %>"
            }
        };

    </script>

    <script>

        const buttons = document.querySelectorAll(".variant-btn");

        buttons.forEach(button => {

            button.addEventListener("click", function () {


                
                buttons.forEach(btn => btn.classList.remove("active"));

                this.classList.add("active");

                const variant = variants[this.dataset.variant];

                if (!variant) return;

                document.getElementById("datasheetLink").href =
                    "/pdf/" + variant.datasheet;

                document.getElementById("catalogLink").href =
                    "/pdf/" + variant.catalog;

                const installation = document.getElementById("installationLink");

                if (installation) {
                    installation.href =
                        "/pdf/" + variant.installation;
                }

            });

        });

    </script>