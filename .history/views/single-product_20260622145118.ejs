<%- include('partials/header') %>

    <style>
        body {
            background: #ffffff;
        }
    </style>

    <section class="single-product-page">
        <div class="container">

          
            <div class="breadcrumb">
                <div class="d-flex align-items-center">

                    <a href="/">Home</a>

                    <span>></span>

                    <span>
                        <%= product.brand || 'Products' %>
                    </span>

                    <span>></span>

                    <span>
                        <%= product.category || 'Category' %>
                    </span>

                    <span>></span>

                    <span>
                        <strong>
                            <%= product.name %>
                        </strong>
                        </span>

                </div>
                </div>

        </div>
      

    </section>

    <section class="single-product-section">

      
        <div class="container">

            <div class="row justify-content-between align-items-center">

                <div class="col-md-5">

                    <div class="product-gallery">

                        <div class="main-image">
                            <img id="mainProductImage" src="/images/<%= product.image %>" alt="<%= product.name %>">
                        </div>

                        <div class="thumbnail-wrapper">

                            <div class="thumbnail active">

                                <img class="thumb" src="/images/<%= product.image %>" onclick="changeImage(this)">

                            </div>

<div class="thumbnail">
    <img class="thumb" src="/images/<%= product.image %>" onclick="changeImage(this)">
</div>

<% if(product.related_image_1){ %>
    <div class="thumbnail">
        <img class="thumb" src="/images/<%= product.related_image_1 %>" onclick="changeImage(this)">
    </div>
    <% } %>

        <% if(product.image3){ %>
            <div class="thumbnail">
                <img class="thumb" src="/images/<%= product.image3 %>" onclick="changeImage(this)">
            </div>
            <% } %>

                            <% if(product.gallery_images){ %>

                                <% JSON.parse(product.gallery_images).forEach(function(img){ %>

                                    <div class="thumbnail">

                                        <img class="thumb" src="/images/<%= img %>" onclick="changeImage(this)">

                                    </div>

                                    <% }) %>

                                        <% } %>

                        </div>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="product-details">

                        <h1 class="product-title">
                            <%= product.name %>
                        </h1>

                        <ul>

                            <% if(product.description){ %>

                                <% product.description.split('\n').forEach(function(line){ %>

                                    <li class="product-description">
                                        <%= line %>
                                    </li>
                                    <% }) %>

                                        <% } %>

                        </ul>

                        <div class="product-actions">

                            <a href="/contact" class="btn btn-theme-danger">
                                Enquiry
                            </a>

                            <% if(product.pdf){ %>

                                <a href="/images/<%= product.pdf %>" class="btn btn-theme-outline" download>
                                    Download
                                </a>

                                <% } %>

                        </div>

                    </div>

                </div>

            </div>

        </div>
      
        
        </section>
        
        <section class="related-products">
        
          
            <div class="container">
        
                <div class="section-header">
        
                    <h2>Related Products</h2>

                <div class="slider-buttons">

                    <button id="prevBtn">
                        <img src="/images/arrow-right-single-product.svg" alt="">
                    </button>

                    <button id="nextBtn">
                        <img src="/images/arrow-right-product-single.svg" alt="">
                    </button>

                </div>

            </div>

            <div class="related-slider" id="relatedSlider">

                <% relatedProducts.forEach(function(item){ %>

                    <div class="related-card">

                        <a href="/product/<%= item.slug %>" class="text-decoration-none text-dark">

                            <div class="related-card-img">

                                <img src="/images/<%= item.image %>" alt="<%= item.name %>">

                            </div>

                            <h5>
                                <%= item.name %>
                            </h5>

                        </a>

                    </div>

                    <% }) %>

            </div>

        </div>
       
        
        </section>
        
        <script>

            function changeImage(element) {
                document.getElementById("mainProductImage").src = element.src;
            }

            const slider = document.getElementById("relatedSlider");

            document.getElementById("nextBtn")?.addEventListener("click", () => {
                slider.scrollBy({
                    left: 350,
                    behavior: "smooth"
                });
            });

            document.getElementById("prevBtn")?.addEventListener("click", () => {
                slider.scrollBy({
                    left: -350,
                    behavior: "smooth"
                });
            });

        </script>

    <%- include('partials/footer') %>


    <div class="container">
    
        <div class="row align-items-center g-5">
    
            <!-- Product Images -->
    
            <div class="col-lg-5">
    
                <div class="product-gallery">
    
                    <div class="main-image text-center mb-3">
    
                        <img id="mainProductImage" src="/images/<%= product.image %>" alt="<%= product.name %>"
                            class="img-fluid border rounded p-3">
    
                    </div>
    
                    <div class="d-flex gap-3 justify-content-center">
    
                        <% if(product.image){ %>
                            <div class="thumbnail">
                                <img src="/images/<%= product.image %>" class="thumb active" onclick="changeImage(this)"
                                    width="80">
                            </div>
                            <% } %>
    
                                <% if(product.related_image_1){ %>
                                    <div class="thumbnail">
                                        <img src="/images/<%= product.related_image_1 %>" class="thumb"
                                            onclick="changeImage(this)" width="80">
                                    </div>
                                    <% } %>
    
                                        <% if(product.image3){ %>
                                            <div class="thumbnail">
                                                <img src="/images/<%= product.image3 %>" class="thumb"
                                                    onclick="changeImage(this)" width="80">
                                            </div>
                                            <% } %>
    
                    </div>
    
                </div>
    
            </div>
    
            <!-- Product Details -->
    
            <div class="col-lg-7">
    
                <h1 class="mb-4">
                    <%= product.name %>
                </h1>
    
                <div class="product-description mb-4">
    
                    <%= product.description %>
    
                </div>
    
                <div class="d-flex gap-3">
    
                    <a href="/contact" class="btn btn-danger">
                        Enquiry
                    </a>
    
                    <% if(product.pdf){ %>
    
                        <a href="/pdf/<%= product.pdf %>" class="btn btn-outline-dark" download>
                            Download PDF
                        </a>
    
                        <% } %>
    
                </div>
    
            </div>
    
        </div>
    
    </div>
    <div class="container">
    
        <div class="d-flex justify-content-between align-items-center mb-4">
    
            <h2>Related Products</h2>
    
            <div>
    
                <button class="btn btn-outline-dark me-2" id="prevBtn">
                    ←
                </button>
    
                <button class="btn btn-outline-dark" id="nextBtn">
                    →
                </button>
    
            </div>
    
        </div>
    
        <div class="related-slider d-flex gap-4 overflow-auto" id="relatedSlider">
    
            <% relatedProducts.forEach(item=> { %>
    
                <% if(item.id !==product.id){ %>
    
                    <a href="/product/<%= item.slug %>" class="text-decoration-none text-dark">
    
                        <div class="related-card border rounded p-3 text-center" style="min-width:250px;">
    
                            <img src="/images/<%= item.image %>" class="img-fluid mb-3" alt="<%= item.name %>">
    
                            <h6>
                                <%= item.name %>
                            </h6>
    
                        </div>
    
                    </a>
    
                    <% } %>
    
                        <% }) %>
    
        </div>
    
    </div>