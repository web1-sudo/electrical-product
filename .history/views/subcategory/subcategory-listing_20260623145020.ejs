<%- include('../partials/header') %>

    <section class="product-page py-5">

        <div class="container">

            <!-- Breadcrumb -->

            <div class="breadcrumb mb-4">

                <a href="/">Home</a>

                <span> ></span>

                <a href="/products">Products</a>

                <span> ></span>

                <a href="/products/<%= categorySlug %>">
                    <%= categoryName %>
                </a>

                <span> ></span>

                <a href="/products/<%= categorySlug %>/<%= brandSlug %>">
                    <%= brandName %>
                </a>

                <span> ></span>

                <strong>
                    <%= subcategoryName %>
                </strong>

            </div>

            <div class="row">
<!-- <h2>Total Products: <%= products.length %> -->
</h2>
                <!-- FILTER SIDEBAR -->

                <div class="col-lg-3">

                    <form method="GET" id="filterForm">

                        <% if(brandSlug==='eq9' ){ %>

                            <div class="filter">

                                <h3>Filters</h3>

                                <!-- CURRENT RATING -->

                                <div class="dropdown-item">

                                    <input type="checkbox" id="drop1" class="dropdown-check">

                                    <label for="drop1" class="dropdown-header">

                                        <span>Current Rating</span>

                                    </label>

                                    <div class="dropdown-content">

                                       
    <input type="checkbox" class="filter-check" name="rating" value="2A" <%=Array.isArray(selectedFilters.rating) ?
        selectedFilters.rating.includes('2A') : selectedFilters.rating==='2A' ? 'checked' : '' %>
    >
                                        <label>2A</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="rating" value="6A">
<input type="checkbox" class="filter-check" name="rating" value="2A" <%=Array.isArray(selectedFilters.rating) ?
    selectedFilters.rating.includes('2A') : selectedFilters.rating==='2A' ? 'checked' : '' %>
>
                                        <label>6A</label>

                                    </div>

                                    <div class="dropdown-content">

                            <input type="checkbox" class="filter-check" name="rating" value="10A" <%=Array.isArray(selectedFilters.rating) ?
                                selectedFilters.rating.includes('10A') : selectedFilters.rating==='10A' ? 'checked' : '' %>
                            >

                                        <label>10A</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="rating" value="16A">

                                        <label>16A</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="rating" value="20A">

                                        <label>20A</label>

                                    </div>

                                </div>

                                <!-- CURVE TYPE -->

                                <div class="dropdown-item">

                                    <input type="checkbox" id="drop2" class="dropdown-check">

                                    <label for="drop2" class="dropdown-header">

                                        <span>Curve Type</span>

                                    </label>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="curve_type" value="B">

                                        <label>B</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="curve_type" value="C">

                                        <label>C</label>

                                    </div>

                                </div>

                                <!-- POLES -->

                                <div class="dropdown-item">

                                    <input type="checkbox" id="drop3" class="dropdown-check">

                                    <label for="drop3" class="dropdown-header">

                                        <span>No Of Poles</span>

                                    </label>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="poles" value="Single Pole">

                                        <label>Single Pole</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="poles" value="Double Pole">

                                        <label>Double Pole</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="poles" value="Three Pole">

                                        <label>Three Pole</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="poles" value="Four Pole">

                                        <label>Four Pole</label>

                                    </div>

                                </div>

                            </div>

                            <% } %>

                                <% if(brandSlug==='auralis' ){ %>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="boards" value="4 Way">

                                        <label>4 Way</label>

                                    </div>

                                    <div class="dropdown-content">

                                        <input type="checkbox" class="filter-check" name="boards_type" value="SPN">

                                        <label>SPN</label>

                                    </div>

                                    <% } %>

                                        <% if(brandSlug==='elvo' ){ %>

                                            <div class="dropdown-content">

                                                <input type="checkbox" class="filter-check" name="boards"
                                                    value="4 Way">

                                                <label>4 Way</label>

                                            </div>

                                            <% } %>

                                                <% if(brandSlug==='avina' ){ %>

                                                    <div class="dropdown-content">

                                                        <input type="checkbox" class="filter-check" name="boards_type"
                                                            value="TPN">

                                                        <label>TPN</label>

                                                    </div>

                                                    <% } %>

                    </form>

                </div>

                <!-- PRODUCTS -->

                <div class="col-lg-9">

                    <div class="row g-4">

                        <% products.forEach(function(product){ %>

                            <div class="col-lg-4 col-md-6">

                                <a href="/product/<%= product.slug %>" class="text-decoration-none text-dark">

                                    <div class="product-card">

                                        <div class="product-card-image">

                                            <img src="/images/<%= product.image %>" alt="<%= product.name %>"
                                                class="img-fluid">

                                        </div>

                                        <div class="product-card-content text-center">

                                            <h5>
                                                <%= product.name %>
                                            </h5>

                                        </div>

                                    </div>

                                </a>

                            </div>

                            <% }) %>

                    </div>
<% if(totalPages> 1){ %>

    <div class="row justify-content-center mt-5">

        <div class="col-auto">

            <nav>

                <ul class="pagination">

                    <% if(page> 1){ %>

                        <li class="page-item">

                            <a class="page-link" href="?page=<%= page - 1 %>">
                                &lt;
                            </a>

                        </li>

                        <% } %>

                            <% for(let i=1;i<=totalPages;i++){ %>

                                <li class="page-item <%= page===i ? 'active' : '' %>">

                                    <a class="page-link" href="?page=<%= i %>">
                                        <%= i %>
                                    </a>

                                </li>

                                <% } %>

                                    <% if(page < totalPages){ %>

                                        <li class="page-item">

                                            <a class="page-link" href="?page=<%= page + 1 %>">
                                                &gt;
                                            </a>

                                        </li>

                                        <% } %>

                </ul>

            </nav>

        </div>

    </div>

    <% } %>
                </div>

            </div>

        </div>

    </section>

    <script>

        document.querySelectorAll('.filter-check').forEach(item => {

            item.addEventListener('change', () => {

                document.getElementById('filterForm').submit();

            });

        });

    </script>

    <%- include('../partials/footer') %>